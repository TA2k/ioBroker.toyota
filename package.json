{
  "name": "iobroker.toyota",
  "version": "0.2.6",
  "description": "Adapter for myT Toyota/Lexus App",
  "author": {
    "name": "TA2k",
    "email": "tombox2020@gmail.com"
  },
  "contributors": [
    {
      "name": "TA2k"
    }
  ],
  "homepage": "https://github.com/TA2k/ioBroker.toyota",
  "license": "MIT",
  "keywords": [
    "toyota",
    "lexus",
    "myt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TA2k/ioBroker.toyota"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "axios": "^1.18.0",
    "http-cookie-agent": "^8.0.0",
    "json2iob": "^2.6.25",
    "jsonwebtoken": "^9.0.3",
    "qs": "^6.15.2",
    "tough-cookie": "^6.0.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^22.20.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript": "~6.0.3"
  },
  "main": "main.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint"
  },
  "bugs": {
    "url": "https://github.com/TA2k/ioBroker.toyota/issues"
  },
  "readmeFilename": "README.md"
}
